/**
 * ==========================================================================
 * 범용 만족도 조사 동적 분석
 * ==========================================================================
 *
 * 현재 단계:
 * - 10_문항매핑과 09_범용원자료를 읽습니다.
 * - 문항명과 컬럼 순서가 서로 일치하는지 확인합니다.
 *
 * 아직 통계 시트나 보고서는 생성하지 않습니다.
 */


/**
 * 범용 설문 분석에 필요한 원자료와 문항 매핑을 불러옵니다.
 *
 * @return {Object}
 */
function getDynamicSurveySource_() {
  const spreadsheet =
    SpreadsheetApp.getActiveSpreadsheet();

  const mappingSheet =
    spreadsheet.getSheetByName(
      "10_문항매핑"
    );

  const rawSheet =
    spreadsheet.getSheetByName(
      "09_범용원자료"
    );


  if (
    !mappingSheet
    || mappingSheet.getLastRow() < 2
  ) {
    throw new Error(
      "10_문항매핑 시트에 저장된 문항 정보가 없습니다."
    );
  }


  if (
    !rawSheet
    || rawSheet.getLastRow() < 2
  ) {
    throw new Error(
      "09_범용원자료 시트에 응답 데이터가 없습니다."
    );
  }


  const mappingTable = mappingSheet.getDataRange().getDisplayValues();
  const mappingHeaders = mappingTable[0];
  const mappingValues = mappingTable.slice(1);


  const rawValues =
    rawSheet
      .getDataRange()
      .getDisplayValues();


  const rawHeaders =
    rawValues[0]
      .map(function(value) {
        return cleanText_(value);
      });


  function mappingValue_(row, name, legacyIndex) {
    const index = mappingHeaders.indexOf(name);
    return row[index >= 0 ? index : legacyIndex] || "";
  }

  const mappings =
    mappingValues.map(function(row) {
      const selectedType = cleanText_(mappingValue_(row, "최종 선택 유형", 5)
        || mappingValue_(row, "자동 추천 유형", 4)).toUpperCase();
      return {
        order:
          Number(mappingValue_(row, "순번", 0) || 0),

        columnNumber:
          Number(mappingValue_(row, "원본 컬럼번호", 1) || 0),

        originalHeader:
          cleanText_(mappingValue_(row, "원본 문항", 2)),

        sampleValue:
          cleanText_(mappingValue_(row, "예시 응답", 3)),

        suggestedType:
          cleanText_(mappingValue_(row, "자동 추천 유형", 4)),

        selectedType:
          selectedType,

        analysisTarget: mappingHeaders.indexOf("분석대상") >= 0
          ? String(mappingValue_(row, "분석대상", 10)).toUpperCase() === "TRUE"
          : selectedType !== "EXCLUDE" && selectedType !== "PERSONAL_INFO",

        groupId: cleanText_(mappingValue_(row, "그룹 ID", 11)),
        matrixId: cleanText_(mappingValue_(row, "행렬 ID", 12)),
        scaleKind: cleanText_(mappingValue_(row, "척도 유형", 13)),
        scoreMap: parseSurveyMappingScoreMap_(mappingValue_(row, "점수 매핑 JSON", 14))
      };
    });


  const errors = [];


  mappings.forEach(function(mapping) {
    const rawHeader =
      rawHeaders[
        mapping.columnNumber - 1
      ] || "";

    if (
      normalizeHeader_(rawHeader)
      !== normalizeHeader_(
        mapping.originalHeader
      )
    ) {
      errors.push(
        mapping.columnNumber
        + "번 컬럼 불일치: "
        + mapping.originalHeader
        + " / "
        + rawHeader
      );
    }
  });


  if (errors.length > 0) {
    throw new Error(
      "문항 매핑과 범용 원자료가 일치하지 않습니다.\n- "
      + errors.join("\n- ")
    );
  }


  return {
    headers:
      rawHeaders,

    rows:
      rawValues.slice(1),

    mappings:
      mappings,

    respondentCount:
      rawValues.length - 1,

    questionCount:
      mappings.length
  };
}


/**
 * 편집기에서 범용 원자료 연결 상태를 검사합니다.
 */
function testDynamicSurveySource() {
  const result =
