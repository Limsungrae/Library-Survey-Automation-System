/**
 * ==========================================================================
 * 성남시중원도서관 만족도 조사 자동화 시스템
 * 웹페이지 전용 서비스
 * ==========================================================================
 *
 * 담당 기능
 * 1. 웹페이지에서 원자료 상태 조회
 * 2. 통계 보고서 생성
 * 3. AI 포함 전체 보고서 생성
 * 4. AI 보고서만 다시 생성
 * 5. 대시보드 요약 데이터 반환
 * 6. Excel 보고서 생성 및 다운로드 URL 반환
 *
 * 주의
 * - saveSurveySettingsFromWeb(), getSurveySettingsForWeb()는
 *   07_SurveyReport.gs에 이미 있으므로 이 파일에서 다시 선언하지 않습니다.
 * - uploadSurveyExcelFromWeb(), validateRawSheetFromWeb()는
 *   04_SurveyImport.gs에 이미 있으므로 다시 선언하지 않습니다.
 */


// ==========================================================================
// 원자료 및 시스템 상태 조회
// ==========================================================================

/**
 * 웹페이지가 처음 열릴 때 현재 시스템 상태를 반환합니다.
 *
 * @return {Object}
 */
function getSurveySystemStatusFromWeb() {
  try {
    const spreadsheet =
      SpreadsheetApp.getActiveSpreadsheet();

    const rawSheet =
      spreadsheet.getSheetByName(
        APP_CONFIG.SOURCE_SHEET
      );

    const settingsSheetName =
      APP_CONFIG.SETTINGS_SHEET
      || "00_설정";

    const settingsSheet =
      spreadsheet.getSheetByName(
        settingsSheetName
      );


    let rowCount = 0;
    let rawSheetValid = false;
    let rawSheetMessage =
      "원자료가 아직 등록되지 않았습니다.";


    if (
      rawSheet
      && rawSheet.getLastRow() > 1
    ) {
      try {
        const validation =
          validateRawSheet_();

        rowCount =
          validation.rowCount;

        rawSheetValid =
          true;

        rawSheetMessage =
          "응답 "
          + rowCount
          + "건이 등록되어 있습니다.";

      } catch (error) {
        rawSheetMessage =
          error && error.message
            ? error.message
            : String(error);
      }
    }


    const existingReportSheets =
      APP_CONFIG.REPORT_SHEETS
        .filter(function(sheetName) {
          return Boolean(
            spreadsheet.getSheetByName(
              sheetName
            )
          );
        });


    return {
      success:
        true,

      settingsExists:
        Boolean(settingsSheet),

      rawSheetExists:
        Boolean(rawSheet),

      rawSheetValid:
        rawSheetValid,

      rowCount:
        rowCount,

      rawSheetMessage:
        rawSheetMessage,

      reportSheetCount:
        existingReportSheets.length,

      reportSheets:
        existingReportSheets,

      allReportSheetsExist:
        APP_CONFIG.REPORT_SHEETS
          .every(function(sheetName) {
            return Boolean(
              spreadsheet.getSheetByName(
                sheetName
              )
            );
          })
    };

  } catch (error) {
    return {
      success:
        false,

      error:
        getWebErrorMessage_(
          error
        )
    };
  }
}
/**
 * 범용 만족도 조사 시스템의 현재 상태를 반환합니다.
 *
 * 확인 항목:
 * - 00_설정
 * - 10_문항매핑
 * - 09_범용원자료
 * - 01~06 범용 통계 보고서
 * - 07_AI총평
 * - 08_향후계획
 *
 * @return {Object}
 */
function getDynamicSurveySystemStatusFromWeb() {
  try {
    const spreadsheet =
      SpreadsheetApp.getActiveSpreadsheet();

    const settingsSheet =
      spreadsheet.getSheetByName(
        "00_설정"
      );

    const mappingSheet =
      spreadsheet.getSheetByName(
        "10_문항매핑"
      );

    const rawSheet =
      spreadsheet.getSheetByName(
        "09_범용원자료"
      );

    const statisticalSheetNames = [
      "01_조사개요",
      "02_대시보드",
      "03_응답자특성",
      "04_단일응답분석",
      "05_복수응답분석",
      "06_척도분석",
      "07_추천지수분석",
      "08_주관식분석"
    ];

    const aiSheetNames = [
      "09_AI총평",
      "10_향후계획"
    ];

    const statisticalSheetCount =
      statisticalSheetNames.filter(function(sheetName) {
        return Boolean(
          spreadsheet.getSheetByName(
            sheetName
          )
        );
      }).length;

    const aiSheetCount =
      aiSheetNames.filter(function(sheetName) {
        return Boolean(
          spreadsheet.getSheetByName(
            sheetName
          )
        );
      }).length;

    const mappingCount =
      mappingSheet
      && mappingSheet.getLastRow() >= 2
        ? mappingSheet.getLastRow() - 1
        : 0;

    const respondentCount =
      rawSheet
      && rawSheet.getLastRow() >= 2
        ? rawSheet.getLastRow() - 1
        : 0;

    const rawColumnCount =
      rawSheet
        ? rawSheet.getLastColumn()
        : 0;

    const settingsExists =
      Boolean(
        settingsSheet
        && settingsSheet.getLastRow() >= 2
      );

    const mappingExists =
      mappingCount > 0;

    const rawSheetExists =
      respondentCount > 0;

    const statisticsComplete =
      statisticalSheetCount
      === statisticalSheetNames.length;

    const aiComplete =
      aiSheetCount
      === aiSheetNames.length;

    const exportReady =
      settingsExists
      && mappingExists
      && rawSheetExists
      && statisticsComplete;

    return {
      success: true,

      settingsExists:
        settingsExists,

      mappingExists:
        mappingExists,

      mappingCount:
        mappingCount,

      rawSheetExists:
        rawSheetExists,

      respondentCount:
        respondentCount,

      rawColumnCount:
        rawColumnCount,

      statisticalSheetCount:
        statisticalSheetCount,

      statisticalSheetTotal:
        statisticalSheetNames.length,

      statisticsComplete:
        statisticsComplete,

      aiSheetCount:
        aiSheetCount,

      aiSheetTotal:
        aiSheetNames.length,

      aiComplete:
        aiComplete,

      exportReady:
        exportReady,

      message:
        "범용 시스템 상태를 확인했습니다."
    };

  } catch (error) {
    return {
      success: false,

      error:
        error && error.message
          ? error.message
          : String(error)
    };
  }
}



