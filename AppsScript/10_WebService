/**
 * 범용 만족도 조사 대시보드 데이터를 웹페이지로 반환합니다.
 *
 * 기준 데이터:
 * - 09_범용원자료
 * - 10_문항매핑
 *
 * @return {Object}
 */
function getDynamicSurveyDashboardDataFromWeb() {
  try {
    const analysis =
      calculateDynamicSurveyAnalysis_();

    const recommendation =
      analysis.recommendation
      && analysis.recommendation.length > 0
        ? analysis.recommendation[0]
        : null;

    return {
      success: true,

      summary: {
        totalRespondents:
          analysis.respondentCount,

        overallAverage:
          analysis.scaleSummary.overallAverage,

        overallConverted100:
          analysis.scaleSummary.overallConverted100,

        overallPositiveRate:
          analysis.scaleSummary.overallPositiveRate,

        recommendationAverage:
          recommendation
            ? recommendation.average
            : 0,

        recommendationPositiveRate:
          recommendation
            ? recommendation.positiveRate
            : 0,

        analyzedQuestionCount: analysis.summary.analyzedQuestionCount,
        opinionCount: analysis.summary.opinionCount,
        missingRate: analysis.summary.missingRate,
        nps: recommendation && recommendation.scaleMode === "NPS_0_10"
          ? recommendation.nps : 0
      },

      satisfaction:
        analysis.scale.map(function(item) {
          return {
            questionNo:
              "Q" + item.columnNumber,

            label:
              item.question,

            average:
              item.average,

            converted100:
              item.converted100,

            positiveRate:
              item.positiveRate,

            rank:
              item.rank
          };
        }),

      multiple:
        analysis.multiple.map(function(question) {
          return {
            question:
              question.question,

            items:
              question.items
                .slice(0, 5)
                .map(function(item) {
                  return {
                    label:
                      item.label,

                    count:
                      item.count,

                    selectionRate:
                      item.selectionRate,

                    respondentRate:
                      item.respondentRate
                  };
                })
          };
        }),

      respondent: (analysis.respondent || []).map(function(question) {
        return {question: question.question, items: (question.items || []).slice(0, 10)};
      }),

      composition: (analysis.scale || []).map(function(item) {
        return {label: item.question, positiveRate: item.positiveRate,
          neutralRate: item.neutralRate, negativeRate: item.negativeRate};
      }),

      message:
        "범용 대시보드 데이터를 불러왔습니다."
    };

  } catch (error) {
    return {
      success: false,

      error:
        error && error.message
          ? error.message
          : String(error)
    };
  }
}

/**
 * 웹 KPI 카드에 표시할 핵심 요약값을 생성합니다.
 *
 * @param {Object} analysis 설문 분석 결과
 * @return {Object}
 */
function buildSurveyDashboardSummary_(
  analysis
) {
  return {
    totalRespondents:
      Number(
        analysis.totalRespondents
        || 0
      ),

    overallAverage:
      Number(
        analysis.overallAverage
        || 0
      ),

    overallConverted100:
      Number(
        analysis.overallConverted100
        || 0
      ),

    overallPositiveRate:
      Number(
        analysis.overallPositiveRate
        || 0
      ),

    recommendationAverage:
      Number(
        analysis.recommendation
        && analysis.recommendation.average
          ? analysis.recommendation.average
          : 0
      ),

    recommendationPositiveRate:
      Number(
        analysis.recommendation
        && analysis.recommendation.positiveRate
          ? analysis.recommendation.positiveRate
          : 0
      ),

    topUserType:
      analysis.userTypes
      && analysis.userTypes.length
        ? analysis.userTypes[0]
        : null,

    highestSatisfaction:
      getHighestSatisfactionItem_(
        analysis.satisfaction
      ),

    lowestSatisfaction:
      getLowestSatisfactionItem_(
        analysis.satisfaction
      )
  };
}


/**
 * 만족도 최고 항목을 반환합니다.
 */
function getHighestSatisfactionItem_(
  satisfaction
) {
  if (
    !Array.isArray(satisfaction)
    || satisfaction.length === 0
  ) {
    return null;
  }


  return satisfaction
    .slice()
    .sort(function(a, b) {
      return (
        Number(b.average || 0)
        - Number(a.average || 0)
      );
    })[0];
}


/**
 * 만족도 최저 항목을 반환합니다.
 */
function getLowestSatisfactionItem_(
  satisfaction
) {
  if (
    !Array.isArray(satisfaction)
    || satisfaction.length === 0
  ) {
    return null;
  }


  return satisfaction
    .slice()
    .sort(function(a, b) {
      return (
        Number(a.average || 0)
        - Number(b.average || 0)
      );
    })[0];
}


