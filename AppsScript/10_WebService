/** Dynamic survey web services. */

/**
 * 범용 만족도 조사 시스템의 현재 상태를 반환합니다.
 *
 * 확인 항목:
 * - 00_설정
 * - 10_문항매핑
 * - 09_범용원자료
 * - 01~06 범용 통계 보고서
 * - 07_AI총평
 * - 08_향후계획
 *
 * @return {Object}
 */
function getDynamicSurveySystemStatusFromWeb() {
  try {
    const spreadsheet =
      SpreadsheetApp.getActiveSpreadsheet();

    const settingsSheet =
      spreadsheet.getSheetByName(
        "00_설정"
      );

    const qualitySheet = spreadsheet.getSheetByName(
      DYNAMIC_SURVEY_CONFIG.SHEETS.QUALITY
    );
    const qualityStatus = qualitySheet
      ? cleanText_(qualitySheet.getRange("B5").getDisplayValue())
      : "NOT_RUN";
    const qualityAiAllowed = qualitySheet
      ? qualitySheet.getRange("B8").getDisplayValue() === "가능"
      : false;

    const mappingSheet = spreadsheet.getSheetByName(DYNAMIC_SURVEY_CONFIG.SHEETS.MAPPING)
      || spreadsheet.getSheetByName(DYNAMIC_SURVEY_CONFIG.SHEETS.LEGACY_MAPPING);

    const rawSheet = spreadsheet.getSheetByName(DYNAMIC_SURVEY_CONFIG.SHEETS.RAW)
      || spreadsheet.getSheetByName(DYNAMIC_SURVEY_CONFIG.SHEETS.LEGACY_RAW);

    const statisticalSheetNames = [
      "01_조사개요",
      "00_품질검사",
      "02_대시보드",
      "03_응답자특성",
      "04_단일응답분석",
      "05_복수응답분석",
      "06_척도분석",
      "07_추천의향분석",
      "08_주관식분석"
    ];

    const aiSheetNames = [
      "09_AI총평",
      "10_향후계획"
    ];

    const statisticalSheetCount =
      statisticalSheetNames.filter(function(sheetName) {
        return Boolean(
          spreadsheet.getSheetByName(
            sheetName
          )
        );
      }).length;

    const aiSheetCount =
      aiSheetNames.filter(function(sheetName) {
        return Boolean(
          spreadsheet.getSheetByName(
            sheetName
          )
        );
      }).length;

    const mappingCount =
      mappingSheet
      && mappingSheet.getLastRow() >= 2
        ? mappingSheet.getLastRow() - 1
        : 0;

    const respondentCount =
      rawSheet
      && rawSheet.getLastRow() >= 2
        ? rawSheet.getLastRow() - 1
        : 0;

    const rawColumnCount =
      rawSheet
        ? rawSheet.getLastColumn()
        : 0;

    const settingsExists =
      Boolean(
        settingsSheet
        && settingsSheet.getLastRow() >= 2
      );

    const mappingExists =
      mappingCount > 0;

    const rawSheetExists =
      respondentCount > 0;

    const statisticsComplete =
      statisticalSheetCount
      === statisticalSheetNames.length;

    const aiComplete =
      aiSheetCount
      === aiSheetNames.length;

    const exportReady =
      settingsExists
      && mappingExists
      && rawSheetExists
      && statisticsComplete
      && qualityStatus !== "FAIL";

    return {
      success: true,

      settingsExists:
        settingsExists,

      mappingExists:
        mappingExists,

      mappingCount:
        mappingCount,

      rawSheetExists:
        rawSheetExists,

      respondentCount:
        respondentCount,

      rawColumnCount:
        rawColumnCount,

      statisticalSheetCount:
        statisticalSheetCount,

      statisticalSheetTotal:
        statisticalSheetNames.length,

      statisticsComplete:
        statisticsComplete,

      aiSheetCount:
        aiSheetCount,

      aiSheetTotal:
        aiSheetNames.length,

      aiComplete:
        aiComplete,

      exportReady:
        exportReady,

      qualityStatus: qualityStatus,
      qualityAiAllowed: qualityAiAllowed,

      message:
        "범용 시스템 상태를 확인했습니다."
    };

  } catch (error) {
    return {
      success: false,

      error:
        error && error.message
          ? error.message
          : String(error)
    };
  }
}



