/**
 * 범용 만족도 조사 대시보드 데이터를 웹페이지로 반환합니다.
 *
 * 기준 데이터:
 * - 09_범용원자료
 * - 10_문항매핑
 *
 * @return {Object}
 */
function getDynamicSurveyDashboardDataFromWeb() {
  try {
    const source=getDynamicSurveySource_();
    const analysis=calculateDynamicSurveyAnalysis_(source);
    const quality=validateDynamicSurveyQuality_(analysis,source);
    const npsItems=(analysis.recommendation||[]).filter(function(item){return item.scaleKind==="NPS_0_10";});
    const fivePointItems=(analysis.recommendation||[]).filter(function(item){return item.scaleKind==="RECOMMENDATION_1_5";});

    return {
      success: true,

      summary: {
        totalRespondents:
          analysis.respondentCount,

        overallAverage:
          analysis.scaleSummary.weightedAverage,

        overallConverted100:
          analysis.scaleSummary.overallConverted100,

        overallPositiveRate:
          analysis.scaleSummary.overallPositiveRate,

        recommendationAverage:
          fivePointItems.length ? fivePointItems[0].average : null,

        recommendationPositiveRate:
          fivePointItems.length ? fivePointItems[0].positiveRate : null,

        analyzedQuestionCount: analysis.summary.analyzedQuestionCount,
        opinionCount: analysis.summary.opinionCount,
        missingRate: analysis.summary.missingRate,
        nps: npsItems.length ? npsItems[0].nps : null,
        npsStatus: npsItems.length ? "산출" : "NPS 문항 없음",
        qualityStatus: quality.status,
        aiAllowed: quality.aiAllowed
      },

      satisfaction:
        analysis.scale.map(function(item) {
          return {
            questionNo:
              "Q" + item.columnNumber,

            label:
              item.question,

            average:
              item.average,

            converted100:
              item.converted100,

            positiveRate:
              item.positiveRate,

            rank:
              item.rank
          };
        }),

      multiple:
        analysis.multiple.map(function(question) {
          return {
            question:
              question.question,

            items:
              question.items
                .slice(0, 5)
                .map(function(item) {
                  return {
                    label:
                      item.label,

                    count:
                      item.count,

                    selectionRate:
                      item.selectionRate,

                    respondentRate:
                      item.respondentRate
                  };
                })
          };
        }),

      respondent: (analysis.respondent || []).map(function(question) {
        return {question: question.question, items: (question.items || []).slice(0, 10)};
      }),

      composition: (analysis.scale || []).map(function(item) {
        return {label: item.question, positiveRate: item.positiveRate,
          neutralRate: item.neutralRate, negativeRate: item.negativeRate};
      }),

      recommendations: analysis.recommendation || [],
      quality: quality,

      message:
        "범용 대시보드 데이터를 불러왔습니다."
    };

  } catch (error) {
    return {
      success: false,

      error:
        error && error.message
          ? error.message
          : String(error)
    };
  }
}

/**
 * 웹 KPI 카드에 표시할 핵심 요약값을 생성합니다.
 *
 * @param {Object} analysis 설문 분석 결과
 * @return {Object}
 */
function buildSurveyDashboardSummary_(
  analysis
) {
  return {
    totalRespondents:
      Number(
        analysis.totalRespondents
        || 0
      ),

    overallAverage:
      Number(
        analysis.overallAverage
        || 0
      ),

    overallConverted100:
      Number(
        analysis.overallConverted100
        || 0
      ),

    overallPositiveRate:
      Number(
        analysis.overallPositiveRate
        || 0
      ),

    recommendationAverage:
      Number(
        analysis.recommendation
        && analysis.recommendation.average
          ? analysis.recommendation.average
          : 0
      ),

    recommendationPositiveRate:
      Number(
        analysis.recommendation
        && analysis.recommendation.positiveRate
          ? analysis.recommendation.positiveRate
          : 0
      ),

    topUserType:
      analysis.userTypes
      && analysis.userTypes.length
        ? analysis.userTypes[0]
        : null,

    highestSatisfaction:
      getHighestSatisfactionItem_(
        analysis.satisfaction
      ),

    lowestSatisfaction:
      getLowestSatisfactionItem_(
        analysis.satisfaction
      )
  };
}


/**
 * 만족도 최고 항목을 반환합니다.
 */
function getHighestSatisfactionItem_(
  satisfaction
) {
  if (
    !Array.isArray(satisfaction)
    || satisfaction.length === 0
  ) {
    return null;
  }


  return satisfaction
    .slice()
    .sort(function(a, b) {
      return (
        Number(b.average || 0)
        - Number(a.average || 0)
      );
    })[0];
}


/**
 * 만족도 최저 항목을 반환합니다.
 */
function getLowestSatisfactionItem_(
  satisfaction
) {
  if (
    !Array.isArray(satisfaction)
    || satisfaction.length === 0
  ) {
    return null;
  }


  return satisfaction
    .slice()
    .sort(function(a, b) {
      return (
        Number(a.average || 0)
        - Number(b.average || 0)
      );
    })[0];
}


