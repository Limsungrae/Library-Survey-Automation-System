/**
 * 웹페이지에서 보고서 Excel을 생성하고 파일 URL을 반환합니다.
 *
 * @param {string=} requestedFileName 사용자가 입력한 파일명
 * @return {Object}
 */
function exportSurveyReportFromWeb(
  requestedFileName
) {
  let temporarySpreadsheet = null;

  const lock =
    LockService.getScriptLock();


  try {
    lock.waitLock(
      30000
    );


    const sourceSpreadsheet =
      SpreadsheetApp.getActiveSpreadsheet();


    const missingSheets =
      APP_CONFIG.REPORT_SHEETS
        .filter(function(sheetName) {
          return !sourceSpreadsheet
            .getSheetByName(
              sheetName
            );
        });


    if (
      missingSheets.length > 0
    ) {
      throw new Error(
        "다음 시트가 없습니다.\n- "
        + missingSheets.join(
          "\n- "
        )
        + "\n먼저 전체 보고서를 생성해 주세요."
      );
    }


    let fileName =
      cleanText_(
        requestedFileName
      )
      || buildReportFileName_();


    if (
      !fileName
        .toLowerCase()
        .endsWith(
          ".xlsx"
        )
    ) {
      fileName +=
        ".xlsx";
    }


    fileName =
      sanitizeFileName_(
        fileName
      );


    temporarySpreadsheet =
      SpreadsheetApp.create(
        "TEMP_SURVEY_EXPORT_"
        + Date.now()
      );


    APP_CONFIG.REPORT_SHEETS
      .forEach(function(sheetName) {
        const sourceSheet =
          sourceSpreadsheet
            .getSheetByName(
              sheetName
            );


        sourceSheet
          .copyTo(
            temporarySpreadsheet
          )
          .setName(
            sheetName
          );
      });


    temporarySpreadsheet
      .getSheets()
      .forEach(function(sheet) {
        if (
          !APP_CONFIG.REPORT_SHEETS
            .includes(
              sheet.getName()
            )
        ) {
          temporarySpreadsheet
            .deleteSheet(
              sheet
            );
        }
      });


    APP_CONFIG.REPORT_SHEETS
      .forEach(function(
        sheetName,
        index
      ) {
        const sheet =
          temporarySpreadsheet
            .getSheetByName(
              sheetName
            );


        if (!sheet) {
          return;
        }


        temporarySpreadsheet
          .setActiveSheet(
            sheet
          );


        temporarySpreadsheet
          .moveActiveSheet(
            index + 1
          );
      });


    SpreadsheetApp.flush();

    Utilities.sleep(
      1500
    );


    const exportUrl =
      "https://docs.google.com/spreadsheets/d/"
      + temporarySpreadsheet.getId()
      + "/export?format=xlsx&exportFormat=xlsx";


    const response =
      UrlFetchApp.fetch(
        exportUrl,
        {
          method:
            "get",

          headers: {
            Authorization:
              "Bearer "
              + ScriptApp.getOAuthToken()
          },

          muteHttpExceptions:
            true
        }
      );


    if (
      response.getResponseCode()
      !== 200
    ) {
      throw new Error(
        "Excel 변환에 실패했습니다. HTTP "
        + response.getResponseCode()
      );
    }


    const blob =
      response
        .getBlob()
        .setName(
          fileName
        )
        .setContentType(
          "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
        );


const savedFile =
  DriveApp.createFile(blob);

savedFile.setSharing(
  DriveApp.Access.ANYONE_WITH_LINK,
  DriveApp.Permission.VIEW
);

return {
  success: true,

  message:
    "보고서 Excel 파일을 생성했습니다.",

  fileName:
    savedFile.getName(),

  fileId:
    savedFile.getId(),

  fileUrl: "",

  downloadUrl:
    "https://drive.google.com/uc"
    + "?export=download"
    + "&id="
    + savedFile.getId()
};

  } catch (error) {
    return {
      success:
        false,

      error:
        getWebErrorMessage_(
          error
        )
    };

  } finally {
    if (
      temporarySpreadsheet
    ) {
      try {
        DriveApp
          .getFileById(
            temporarySpreadsheet.getId()
          )
          .setTrashed(
            true
          );
      } catch (ignored) {
        // 임시 파일 삭제 실패는 무시합니다.
      }
    }


    try {
      lock.releaseLock();
    } catch (ignored) {
      // 잠금이 획득되지 않은 경우 무시합니다.
    }
  }
}


// ==========================================================================
// 공통 오류 처리
// ==========================================================================

/**
 * 웹페이지로 전달할 오류 메시지를 정리합니다.
 *
 * @param {*} error
 * @return {string}
 */
function getWebErrorMessage_(
  error
) {
  if (!error) {
    return "알 수 없는 오류가 발생했습니다.";
  }


  if (
    error.message
  ) {
    return String(
      error.message
    );
  }


  return String(
    error
  );
}
