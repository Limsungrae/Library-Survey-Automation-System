/**
 * AI 기능을 제외한 01~05 통계 시트를 생성합니다.
 *
 * @return {Object}
 */
function generateStatisticalSheetsFromWeb() {
  const lock =
    LockService.getScriptLock();

  try {
    lock.waitLock(
      30000
    );


    const settings =
      getSurveySettings_();

    const data =
      getRawSurveyObjects_();

    const analysis =
      calculateSurveyAnalysis_(
        data
      );


    createOverviewSheet_(
      analysis,
      settings
    );

    createDashboardSheet_(
      analysis,
      settings
    );

    createRespondentSheet_(
      analysis,
      settings
    );

    createMultipleAnalysisSheet_(
      analysis,
      settings
    );

    createSatisfactionSheet_(
      analysis,
      settings
    );


    moveReportSheetsInOrder_();

    SpreadsheetApp.flush();


    return {
      success:
        true,

      message:
        "통계 보고서 생성이 완료되었습니다.",

      generatedSheets: [
        "01_조사개요",
        "02_대시보드",
        "03_응답자특성",
        "04_복수응답분석",
        "05_만족도분석"
      ],

      summary:
        buildSurveyDashboardSummary_(
          analysis
        )
    };

  } catch (error) {
    return {
      success:
        false,

      error:
        getWebErrorMessage_(
          error
        )
    };

  } finally {
    try {
      lock.releaseLock();
    } catch (ignored) {
      // 잠금이 획득되지 않은 경우 무시합니다.
    }
  }
}


