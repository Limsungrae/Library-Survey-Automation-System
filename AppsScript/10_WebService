/**
 * 웹페이지로 전달할 오류 메시지를 정리합니다.
 *
 * @param {*} error
 * @return {string}
 */
function getWebErrorMessage_(
  error
) {
  if (!error) {
    return "알 수 없는 오류가 발생했습니다.";
  }


  if (
    error.message
  ) {
    return String(
      error.message
    );
  }


  return String(
    error
  );
}
